VITE_API_BASE_URL=
LLM_BACK_IMAGE=yangyag2/llm-back:latest
LLM_FRONT_IMAGE=yangyag2/llm-front:latest
LLM_FRONT_PORT=8083
LLM_API_BASE_URL=
LLM_JWT_TOKEN=***
LLM_USERNAME=
LLM_PASSWORD=***
APP_CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:8083

APP_DB_HOST=host.docker.internal
APP_DB_PORT=5432
APP_DB_NAME=yangyag
APP_DB_USER=yangyag
APP_DB_PASSWORD=***
APP_DB_SCHEMA=public
APP_ATTACHMENTS_ROOT_PATH=/var/lib/llm/attachments
APP_ATTACHMENTS_MAX_FILE_SIZE=100MB
APP_ATTACHMENTS_MAX_GENERATED_FILE_SIZE=2GB
APP_ATTACHMENTS_MAX_REQUEST_SIZE=100MB
APP_UPLOAD_SESSIONS_ROOT_PATH=/var/lib/llm/upload-sessions
APP_UPLOAD_SESSIONS_EXPIRATION_MS=86400000
APP_UPLOAD_SESSIONS_CLEANUP_FIXED_DELAY_MS=3600000
# Required for production deployment.
APP_JWT_EXPIRATION_MS=3600000
APP_JWT_SECRET=***
APP_UPLOAD_SESSIONS_SECRET=***
LLM_UPLOAD_SESSIONS_SECRET=***
LLM_UPLOAD_CHUNK_SIZE_BASE64_CHARS=1398104

OPENAI_API_KEY=***
OPENAI_MODEL=gpt-5.4
OPENAI_API_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=***
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1

XAI_API_KEY=***
XAI_MODEL=grok-4.20-0309-reasoning
XAI_API_BASE_URL=https://api.x.ai/v1
